# Rust build outputs
/target/
**/*.rs.bk

# Cargo local lock for libraries (uncomment if this is a binary app and you want to commit it)
# Cargo.lock

# Leptos / WASM build outputs
/site/
/dist/
/pkg/

# Trunk / wasm-pack / tool caches
/.trunk/

# Node-related (if using Tailwind/PostCSS tooling)
/node_modules/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment files
.env
.env.*
!.env.example

# IDE / editor
.idea/
.vscode/

# OS files
.DS_Store
Thumbs.db

# Coverage / profiling
/coverage/
*.profraw
*.profdata
